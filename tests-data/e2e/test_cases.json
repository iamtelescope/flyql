      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "pg_array_index_equals",
      "flyql": "tags.0='web'",
      "expected_ids": [1, 3, 5],
      "databases": ["postgresql"]
    },
    {
      "name": "pg_array_index_not_equals",
