{
  "version": "1.0",
  "description": "HAS operator StarRocks generator test cases",
  "test_suite": "has",
  "tests": [
    {
      "name": "has_string_column",
      "input": "message has 'hello'",
      "expected_result": "success",
      "expected_sql": "INSTR(`message`, 'hello') > 0"
    },
    {
      "name": "not_has_string_column",
      "input": "message not has 'hello'",
      "expected_result": "success",
      "expected_sql": "(`message` IS NULL OR INSTR(`message`, 'hello') = 0)"
    },
    {
      "name": "has_array_column",
      "input": "tags has 'value'",
      "expected_result": "success",
      "expected_sql": "array_contains(`tags`, 'value')"
    },
    {
      "name": "not_has_array_column",
      "input": "tags not has 'value'",
      "expected_result": "success",
      "expected_sql": "NOT array_contains(`tags`, 'value')"
    },
    {
      "name": "has_map_column",
      "input": "metadata has 'key'",
      "expected_result": "success",
      "expected_sql": "array_contains(map_keys(`metadata`), 'key')"
    },
    {
      "name": "not_has_map_column",
      "input": "metadata not has 'key'",
      "expected_result": "success",
      "expected_sql": "NOT array_contains(map_keys(`metadata`), 'key')"
    },
    {
      "name": "has_json_column",
      "input": "new_json has 'key'",
      "expected_result": "success",
      "expected_sql": "json_exists(`new_json`, concat('$.', 'key'))"
    },
    {
      "name": "not_has_json_column",
      "input": "new_json not has 'key'",
      "expected_result": "success",
      "expected_sql": "NOT json_exists(`new_json`, concat('$.', 'key'))"
    },
    {
      "name": "has_with_and",
      "input": "message has 'hello' and tags has 'important'",
      "expected_result": "success",
      "expected_sql": "(INSTR(`message`, 'hello') > 0 AND array_contains(`tags`, 'important'))"
    },
    {
      "name": "has_unknown_column",
      "input": "unknown has 'value'",
      "expected_result": "error",
      "expected_error_contains": "unknown column"
    }
  ]
}
