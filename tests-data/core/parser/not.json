          "expression": {
            "key": "a",
            "operator": "=",
            "value": 1.0,
            "value_type": "number"
          },
          "left": null,
          "right": null
        },
        "right": {
          "bool_operator": "",
          "negated": false,
          "expression": {
            "key": "b",
            "operator": "=",
            "value": 2.0,
            "value_type": "number"
          },
          "left": null,
          "right": null
        }
      }
    },
