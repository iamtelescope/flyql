{
  "version": "1.0",
  "description": "E2E test cases shared across databases. Data: 6 rows with id 1-6.",
  "tests": [
    {
      "name": "string_equals",
      "flyql": "message='hello'",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_not_equals",
      "flyql": "message!='hello'",
      "expected_ids": [2, 3, 4, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_like_pattern",
      "flyql": "message like 'hello%'",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_regex_match",
      "flyql": "message~'hello.*'",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_regex_not_match",
      "flyql": "message!~'hello.*'",
      "expected_ids": [2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_equals",
      "flyql": "count=42",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_greater_than",
      "flyql": "count>10",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_less_than",
      "flyql": "count<100",
      "expected_ids": [1, 2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_greater_or_equals",
      "flyql": "count>=100",
      "expected_ids": [3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "float_less_than",
      "flyql": "price<50.0",
      "expected_ids": [1, 3, 4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "float_greater_or_equals",
      "flyql": "price>=50.0",
      "expected_ids": [2, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "bool_truthy",
      "flyql": "active",
      "expected_ids": [1, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "bool_not_truthy",
      "flyql": "not active",
      "expected_ids": [2, 4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "date_less_or_equals",
      "flyql": "created_at<='2023-06-15'",
      "expected_ids": [1, 2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "and_condition",
      "flyql": "active and status=200",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "or_condition",
      "flyql": "env='prod' or env='dev'",
      "expected_ids": [1, 3, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "in_integers",
      "flyql": "status in [200, 201]",
      "expected_ids": [1, 2, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "not_in_integers",
      "flyql": "status not in [200, 404]",
      "expected_ids": [4, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "in_strings",
      "flyql": "env in ['prod', 'staging']",
      "expected_ids": [1, 2, 4, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "truthy_string",
      "flyql": "message",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "truthy_int",
      "flyql": "count",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "not_truthy_string",
      "flyql": "not message",
      "expected_ids": [4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "grouped_logic",
      "flyql": "(status=200 or status=201) and active",
      "expected_ids": [1, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "jsonstring_level1_region",
