      "databases": ["postgresql"]
    },
    {
      "name": "pg_array_index_second_element",
      "flyql": "tags.1='api'",
      "expected_ids": [1, 2],
      "databases": ["postgresql"]
    },
    {
      "name": "pg_map_and_array_combined",
      "flyql": "metadata.tier='premium' and tags.0='web'",
