      "databases": ["postgresql"]
    },
    {
      "name": "json_dotted_key_truthy",
      "flyql": "meta_json.'dc.region'",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["postgresql"]
    },
    {
