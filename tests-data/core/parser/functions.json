{
  "version": "1.0",
  "description": "Temporal function call test cases",
  "test_suite": "functions",
  "tests": [
    {
      "name": "ago_1h",
      "input": "timestamp>ago(1h)",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "timestamp",
          "operator": ">",
          "value": {
            "name": "ago",
            "duration_args": [{"value": 1, "unit": "h"}],
            "unit": "",
            "timezone": ""
          },
          "value_type": "function"
        },
        "left": null,
        "right": null
      }
    },
