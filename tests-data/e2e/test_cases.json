      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "jsonstring_level3_provider_azure",
      "flyql": "meta_str.location.cloud.provider='azure'",
      "expected_ids": [5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_native_level1_region",
      "flyql": "meta_json.region='us-east'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_native_level2_city",
      "flyql": "meta_json.location.city='NYC'",
      "expected_ids": [1, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_native_level3_provider",
      "flyql": "meta_json.location.cloud.provider='aws'",
