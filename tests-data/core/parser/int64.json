{
  "version": "1.0",
  "description": "Large integer (int64) parsing test cases",
  "test_suite": "int64",
  "tests": [
    {
      "name": "int64_positive",
      "input": "id=5145045934107196935",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "id",
          "operator": "=",
          "value": "5145045934107196935",
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "int64_negative",
      "input": "id=-5145045934107196935",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "id",
          "operator": "=",
          "value": "-5145045934107196935",
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "int64_max",
      "input": "id=9223372036854775807",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "id",
          "operator": "=",
          "value": "9223372036854775807",
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "int64_min",
      "input": "id=-9223372036854775808",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "id",
          "operator": "=",
          "value": "-9223372036854775808",
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "uint64_max",
      "input": "id=18446744073709551615",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "id",
          "operator": "=",
          "value": "18446744073709551615",
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    }
  ]
}
