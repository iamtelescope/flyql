{
  "version": "1.0",
  "description": "Shared columns validator test fixtures. Tests validate diagnose() output for column expressions against a column schema and default transformer registry.",
  "test_suite": "columns_validator",
  "tests": [
    {
      "name": "happy_path_single_column",
      "input": "level",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "happy_path_multiple_columns",
      "input": "level, service",
      "capabilities": { "transformers": true },
      "columns": [
        { "name": "level", "type": "string" },
        { "name": "service", "type": "string" }
      ],
      "expected_diagnostics": []
    },
    {
      "name": "happy_path_with_transformer",
      "input": "level|upper",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "unknown_column",
      "input": "foo",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [0, 3],
          "message_contains": "foo"
        }
      ]
    },
    {
      "name": "unknown_column_in_multi",
      "input": "level, foo",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [7, 10],
          "message_contains": "foo"
        }
      ]
    },
    {
      "name": "unknown_transformer",
      "input": "level|nonexistent",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_transformer",
          "severity": "error",
          "range": [6, 17],
          "message_contains": "nonexistent"
        }
      ]
    },
    {
      "name": "chain_type_mismatch",
      "input": "level|len|upper",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "chain_type",
          "severity": "error",
          "range": [10, 15],
          "message_contains": "upper"
        }
      ]
    },
    {
      "name": "multiple_errors",
      "input": "foo, bar",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [0, 3],
          "message_contains": "foo"
        },
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [5, 8],
          "message_contains": "bar"
        }
      ]
    },
    {
      "name": "empty_input",
      "input": "",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "dotted_column_name_unknown",
      "input": "resource.service.name",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [0, 8],
          "message_contains": "resource"
        }
      ]
    },
    {
      "name": "dotted_column_name_known_flat",
      "input": "resource.service.name",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "resource", "type": "string" }],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error", "range": [9, 16], "message_contains": "service" }
      ]
    },
    {
      "name": "dotted_column_name_known_nested",
      "input": "resource.service.name",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "resource", "type": "unknown", "children": { "service": { "name": "service", "type": "unknown", "children": { "name": { "name": "name", "type": "string" } } } } }],
      "expected_diagnostics": []
    },
    {
      "name": "column_without_transformers",
      "input": "level",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "arg_count_too_many",
      "input": "level|upper(1)",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_count",
          "severity": "error",
          "range": [6, 14],
          "message_contains": "upper"
        }
      ]
    },
    {
      "name": "arg_type_mismatch",
      "input": "level|split(42)",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "level", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_type",
          "severity": "error",
          "range": [12, 14],
          "message_contains": "split"
        }
      ]
    },
    {
      "name": "permissive_json_no_children",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_jsonstring_no_children",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "jsonstring" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_map_no_children",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "map" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_unknown_no_children",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "unknown" }],
      "expected_diagnostics": []
    },
    {
      "name": "strict_struct_no_children_errors",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "struct" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [5, 12],
          "message_contains": "message"
        }
      ]
    },
    {
      "name": "strict_scalar_no_children_errors",
      "input": "body.message",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [5, 12],
          "message_contains": "message"
        }
      ]
    },
    {
      "name": "permissive_multi_segment",
      "input": "body.a.b.c.d",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_partial_children",
      "input": "body.declared.known.extra",
      "capabilities": { "transformers": true },
      "columns": [
        {
          "name": "body",
          "type": "json",
          "children": {
            "declared": {
              "name": "declared",
              "type": "json",
              "children": {
                "known": { "name": "known", "type": "json" }
              }
            }
          }
        }
      ],
      "expected_diagnostics": []
    },
    {
      "name": "strict_struct_under_permissive_parent",
      "input": "body.declared.extra",
      "capabilities": { "transformers": true },
      "columns": [
        {
          "name": "body",
          "type": "json",
          "children": {
            "declared": { "name": "declared", "type": "struct" }
          }
        }
      ],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [14, 19],
          "message_contains": "extra"
        }
      ]
    },
    {
      "name": "permissive_then_transformer_no_chain_error",
      "input": "body.message|upper",
      "capabilities": { "transformers": true },
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": []
    }
  ]
}
