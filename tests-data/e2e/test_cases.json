{
  "version": "1.0",
  "description": "E2E test cases shared across databases. Data: 6 rows with id 1-6.",
  "tests": [
    {
      "name": "string_equals",
      "flyql": "message='hello'",
      "expected_ids": [
        1
      ],
      "databases": [
        "clickhouse",
        "postgresql",
        "starrocks"
      ]
    },
    {
      "name": "string_not_equals",
      "flyql": "message!='hello'",
      "expected_ids": [
        2,
        3,
        4,
        5,
        6
      ],
      "databases": [
        "clickhouse",
        "postgresql",
        "starrocks"
      ]
    },
    {
      "name": "string_like_pattern",
      "flyql": "message like 'hello%'",
      "expected_ids": [
        1,
        3,
        6
      ],
      "databases": [
        "clickhouse",
        "postgresql",
        "starrocks"
      ]
    },
