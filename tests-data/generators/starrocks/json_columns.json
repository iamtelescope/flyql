{
  "version": "1.0",
  "description": "JSON columns Starrocks generator test cases",
  "test_suite": "json_columns",
  "tests": [
    {
      "name": "native_json_simple_path",
      "input": "new_json.name='test'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"name\"' = 'test'"
    },
    {
      "name": "native_json_nested_path",
      "input": "new_json.user.name='john'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"user\"'->'\"name\"' = 'john'"
    },
    {
      "name": "native_json_number_value",
      "input": "new_json.age=25",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"age\"' = 25"
    },
    {
      "name": "native_json_underscore_column",
      "input": "new_json.column_name='test'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"column_name\"' = 'test'"
    },
    {
      "name": "native_json_hyphen_column",
      "input": "new_json.column-name='test'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"column-name\"' = 'test'"
    },
    {
      "name": "native_json_dot_in_column",
      "input": "new_json.'column.subcolumn'='test'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"column.subcolumn\"' = 'test'"
    },
    {
      "name": "native_json_not_equals",
      "input": "new_json.status!='active'",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"status\"' != 'active'"
    },
    {
      "name": "native_json_greater_than",
      "input": "new_json.count>100",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"count\"' > 100"
    },
    {
      "name": "native_json_regex_match",
      "input": "new_json.name~'john.*'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) regexp 'john.*'"
    },
    {
      "name": "native_json_regex_not_match",
      "input": "new_json.name!~'john.*'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) NOT regexp 'john.*'"
    },
    {
      "name": "jsonstring_simple_path",
      "input": "json_column.name='test'",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"name\"' = 'test'"
    },
    {
      "name": "jsonstring_nested_path",
      "input": "json_column.user.name='john'",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"user\"'->'\"name\"' = 'john'"
    },
    {
      "name": "jsonstring_number_value",
      "input": "json_column.age=25",
      "expected_result": "success",
      "expected_sql_contains": "parse_json(`json_column`)->'\"age\"' = 25"
    },
    {
      "name": "jsonstring_not_equals",
      "input": "json_column.status!='active'",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"status\"' != 'active'"
    },
    {
      "name": "jsonstring_regex_match",
      "input": "json_column.message~'error.*'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"message\"' as string) regexp 'error.*'"
    },
    {
      "name": "jsonstring_regex_not_match",
      "input": "json_column.message!~'error.*'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"message\"' as string) NOT regexp 'error.*'"
    },
    {
      "name": "native_json_like",
      "input": "new_json.name like 'john%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) LIKE 'john%'"
    },
    {
      "name": "native_json_not_like",
      "input": "new_json.name not like 'john%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) NOT LIKE 'john%'"
    },
    {
      "name": "native_json_ilike",
      "input": "new_json.name ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) ILIKE 'John%'"
    },
    {
      "name": "native_json_not_ilike",
      "input": "new_json.name not ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) NOT ILIKE 'John%'"
    },
    {
      "name": "native_json_nested_path_like",
      "input": "new_json.user.name like 'j%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"user\"'->'\"name\"' as string) LIKE 'j%'"
    },
    {
      "name": "native_json_dot_in_column_like",
      "input": "new_json.'column.subcolumn' like 'v%'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"column.subcolumn\"' as string) LIKE 'v%'"
    },
    {
      "name": "native_json_like_escaped_percent",
      "input": "new_json.name like 'test\\%value'",
      "expected_result": "success",
      "expected_sql": "cast(`new_json`->'\"name\"' as string) LIKE 'test\\\\%value'"
    },
    {
      "name": "jsonstring_like",
      "input": "json_column.name like 'john%'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"name\"' as string) LIKE 'john%'"
    },
    {
      "name": "jsonstring_not_like",
      "input": "json_column.name not like 'john%'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"name\"' as string) NOT LIKE 'john%'"
    },
    {
      "name": "jsonstring_ilike",
      "input": "json_column.name ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"name\"' as string) ILIKE 'John%'"
    },
    {
      "name": "jsonstring_not_ilike",
      "input": "json_column.name not ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "cast(parse_json(`json_column`)->'\"name\"' as string) NOT ILIKE 'John%'"
    },
    {
      "name": "native_json_has",
      "input": "new_json.name has 'john'",
      "expected_result": "success",
      "expected_sql": "INSTR(cast(`new_json`->'\"name\"' as string), 'john') > 0"
    },
    {
      "name": "native_json_not_has",
      "input": "new_json.name not has 'john'",
      "expected_result": "success",
      "expected_sql": "INSTR(cast(`new_json`->'\"name\"' as string), 'john') = 0"
    },
    {
      "name": "native_json_truthy",
      "input": "new_json.name",
      "expected_result": "success",
      "expected_sql": "(`new_json`->'\"name\"' IS NOT NULL)"
    },
    {
      "name": "native_json_falsy",
      "input": "not new_json.name",
      "expected_result": "success",
      "expected_sql": "(`new_json`->'\"name\"' IS NULL)"
    },
    {
      "name": "native_json_in_strings",
      "input": "new_json.name in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"name\"' IN ('a', 'b')"
    },
    {
      "name": "native_json_not_in_strings",
      "input": "new_json.name not in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"name\"' NOT IN ('a', 'b')"
    },
    {
      "name": "native_json_lt",
      "input": "new_json.count < 100",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"count\"' < 100"
    },
    {
      "name": "native_json_ge",
      "input": "new_json.count >= 100",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"count\"' >= 100"
    },
    {
      "name": "native_json_le",
      "input": "new_json.count <= 100",
      "expected_result": "success",
      "expected_sql": "`new_json`->'\"count\"' <= 100"
    },
    {
      "name": "jsonstring_has",
      "input": "json_column.name has 'john'",
      "expected_result": "success",
      "expected_sql": "INSTR(cast(parse_json(`json_column`)->'\"name\"' as string), 'john') > 0"
    },
    {
      "name": "jsonstring_not_has",
      "input": "json_column.name not has 'john'",
      "expected_result": "success",
      "expected_sql": "INSTR(cast(parse_json(`json_column`)->'\"name\"' as string), 'john') = 0"
    },
    {
      "name": "jsonstring_truthy",
      "input": "json_column.name",
      "expected_result": "success",
      "expected_sql": "(json_exists(parse_json(`json_column`), '\"name\"') AND parse_json(`json_column`)->'\"name\"' != '')"
    },
    {
      "name": "jsonstring_falsy",
      "input": "not json_column.name",
      "expected_result": "success",
      "expected_sql": "(`json_column` IS NULL OR NOT json_exists(parse_json(`json_column`), '\"name\"') OR parse_json(`json_column`)->'\"name\"' = '')"
    },
    {
      "name": "jsonstring_falsy_with_transformer",
      "input": "not json_column.name|upper",
      "expected_result": "success",
      "expected_sql": "(`json_column` IS NULL OR NOT json_exists(parse_json(`json_column`), '\"name\"') OR UPPER(cast(parse_json(`json_column`)->'\"name\"' as string)) = '')"
    },
    {
      "name": "jsonstring_in_strings",
      "input": "json_column.name in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"name\"' IN ('a', 'b')"
    },
    {
      "name": "jsonstring_not_in_strings",
      "input": "json_column.name not in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"name\"' NOT IN ('a', 'b')"
    },
    {
      "name": "jsonstring_lt",
      "input": "json_column.count < 100",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"count\"' < 100"
    },
    {
      "name": "jsonstring_ge",
      "input": "json_column.count >= 100",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"count\"' >= 100"
    },
    {
      "name": "jsonstring_le",
      "input": "json_column.count <= 100",
      "expected_result": "success",
      "expected_sql": "parse_json(`json_column`)->'\"count\"' <= 100"
    }
  ]
}
