---
interface Props {
  icon: string
  iconDark?: string
  label: string
  variant?: 'default' | 'go' | 'db'
}

const { icon, iconDark, label, variant = 'default' } = Astro.props

const iconStyle = iconDark
  ? `--tech-icon: url('${icon}'); --tech-icon-dark: url('${iconDark}');`
  : `--tech-icon: url('${icon}'); --tech-icon-dark: url('${icon}');`
---

<span class={`tech-label tech-label--${variant}`}>
  <span class="tech-label__icon" aria-hidden="true" style={iconStyle}></span>
  <span>{label}</span>
</span>

<style>
  .tech-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
  }

  .tech-label__icon {
    width: 1rem;
    height: 1rem;
    flex: none;
    background-image: var(--tech-icon);
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
  }

  .tech-label--go .tech-label__icon {
    width: 1.2rem;
    height: 1.2rem;
  }

  :root[data-theme='dark'] .tech-label__icon {
    background-image: var(--tech-icon-dark);
  }
</style>
