{
  "name": "flyql",
  "version": "0.0.21",
  "description": "A simple query language with parser that transforms queries into Abstract Syntax Tree (AST)",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./core": {
      "import": "./src/core/index.js"
    },
    "./monaco": {
      "import": "./src/monaco/index.js"
    },
    "./columns": {
      "import": "./src/columns/index.js"
    },
    "./columns/*": {
      "import": "./src/columns/*.js"
    },
    "./editor": {
      "import": "./src/editor/index.js"
    },
    "./editor/flyql.css": "./src/editor/flyql.css",
    "./generators/clickhouse": {
      "import": "./src/generators/clickhouse/index.js"
    },
    "./generators/postgresql": {
      "import": "./src/generators/postgresql/index.js"
    },
    "./generators/starrocks": {
      "import": "./src/generators/starrocks/index.js"
    },
    "./matcher": {
      "import": "./src/matcher/index.js"
    }
  },
  "files": [
    "src/**/*.js",
    "src/**/*.vue",
    "src/**/*.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test-script": "node test-script.js",
    "dev": "vite dev",
    "lint": "eslint src/ test/",
    "format": "prettier --write src/ test/"
  },
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "query",
    "parser",
    "ast",
    "sql",
    "filter",
    "vue",
    "javascript"
  ],
  "author": "Ilia (HumanUser) Khomutov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamtelescope/flyql.git",
    "directory": "javascript"
  },
  "bugs": {
    "url": "https://github.com/iamtelescope/flyql/issues"
  },
  "homepage": "https://github.com/iamtelescope/flyql#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.0"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
