          "bool_operator": "",
          "expression": {
            "key": "status",
            "operator": "=",
            "value": {"name": "code", "positional": false},
            "value_type": "parameter"
          },
          "left": null,
          "right": null
        },
        "right": {
          "bool_operator": "",
          "expression": {
            "key": "env",
            "operator": "=",
            "value": {"name": "env", "positional": false},
            "value_type": "parameter"
          },
          "left": null,
          "right": null
        }
      }
    },
