{
  "version": "1.0",
  "description": "Struct column Starrocks generator test cases",
  "test_suite": "struct",
  "tests": [
    {
      "name": "struct_simple_key",
      "input": "object.key1='value1'",
      "expected_result": "success",
      "expected_sql": "`object`.`key1` = 'value1'"
    },
    {
      "name": "struct_dot_in_key_key",
      "input": "object.'nested.key'='value'",
      "expected_result": "success",
      "expected_sql": "`object`.`nested.key` = 'value'"
    },
    {
      "name": "struct_nested_key",
      "input": "object.nested.key='value'",
      "expected_result": "success",
      "expected_sql": "`object`.`nested`.`key` = 'value'"
    },
    {
      "name": "struct_not_equals",
      "input": "object.key1!='value1'",
      "expected_result": "success",
      "expected_sql": "`object`.`key1` != 'value1'"
    },
    {
      "name": "struct_regex_match",
      "input": "object.pattern~'test.*'",
      "expected_result": "success",
      "expected_sql": "`object`.`pattern` regexp 'test.*'"
    },
    {
      "name": "struct_regex_not_match",
      "input": "object.pattern!~'test.*'",
      "expected_result": "success",
      "expected_sql": "`object`.`pattern` NOT regexp 'test.*'"
    },
    {
      "name": "struct_like",
      "input": "object.b like 'alice%'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` LIKE 'alice%'"
    },
    {
      "name": "struct_not_like",
      "input": "object.b not like 'alice%'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` NOT LIKE 'alice%'"
    },
    {
      "name": "struct_ilike",
      "input": "object.b ilike 'Alice%'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` ILIKE 'Alice%'"
    },
    {
      "name": "struct_not_ilike",
      "input": "object.b not ilike 'Alice%'",
      "expected_result": "success",
      "expected_sql": "lower(`object`.`b`) NOT LIKE lower('Alice%')"
    },
    {
      "name": "struct_has",
      "input": "object.b has 'ali'",
      "expected_result": "success",
      "expected_sql": "INSTR(`object`.`b`, 'ali') > 0"
    },
    {
      "name": "struct_not_has",
      "input": "object.b not has 'ali'",
      "expected_result": "success",
      "expected_sql": "INSTR(`object`.`b`, 'ali') = 0"
    },
    {
      "name": "struct_truthy",
      "input": "object.b",
      "expected_result": "success",
      "expected_sql": "(`object`.`b` IS NOT NULL AND `object`.`b` != '')"
    },
    {
      "name": "struct_falsy",
      "input": "not object.b",
      "expected_result": "success",
      "expected_sql": "(`object`.`b` IS NULL OR `object`.`b` = '')"
    },
    {
      "name": "struct_in",
      "input": "object.b in ['alice', 'bob']",
      "expected_result": "success",
      "expected_sql": "`object`.`b` IN ('alice', 'bob')"
    },
    {
      "name": "struct_not_in",
      "input": "object.b not in ['alice', 'bob']",
      "expected_result": "success",
      "expected_sql": "`object`.`b` NOT IN ('alice', 'bob')"
    },
    {
      "name": "struct_gt",
      "input": "object.b > 'a'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` > 'a'"
    },
    {
      "name": "struct_lt",
      "input": "object.b < 'z'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` < 'z'"
    },
    {
      "name": "struct_ge",
      "input": "object.b >= 'a'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` >= 'a'"
    },
    {
      "name": "struct_le",
      "input": "object.b <= 'z'",
      "expected_result": "success",
      "expected_sql": "`object`.`b` <= 'z'"
    }
  ]
}
