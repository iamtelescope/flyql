{
  "version": "1.0",
  "description": "FlyQL truthy expression test cases - standalone keys without operator/value",
  "test_suite": "truthy",
  "tests": [
    {
      "name": "simple_truthy",
      "input": "active",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "negated": false,
        "expression": {
          "key": "active",
          "operator": "truthy",
          "value": "",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "truthy_and_truthy",
      "input": "active and enabled",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "and",
        "negated": false,
        "expression": null,
        "left": {
          "bool_operator": "",
          "negated": false,
          "expression": {
            "key": "active",
            "operator": "truthy",
            "value": "",
            "value_type": "string"
          },
          "left": null,
          "right": null
        },
        "right": {
          "bool_operator": "",
          "negated": false,
          "expression": {
            "key": "enabled",
            "operator": "truthy",
            "value": "",
            "value_type": "string"
          },
          "left": null,
          "right": null
        }
      }
    },
    {
