      }
    },
    {
      "name": "error_startOf_no_args",
      "input": "timestamp>startOf()",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "requires a unit argument"
      }
    },
    {
      "name": "error_startOf_invalid_unit",
      "input": "timestamp>startOf('year')",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "invalid unit 'year'"
      }
    },
    {
      "name": "error_invalid_duration_unit",
      "input": "timestamp>ago(1x)",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "invalid duration unit"
      }
    },
    {
      "name": "error_unclosed_function_1",
      "input": "timestamp>ago(1h",
      "expected_result": "error",
      "expected_error": {
        "errno": 71,
        "message_contains": "unclosed function call"
      }
    },
    {
      "name": "error_unclosed_function_2",
      "input": "timestamp>ago(",
      "expected_result": "error",
      "expected_error": {
        "errno": 71,
        "message_contains": "unclosed function call"
      }
    },
    {
      "name": "error_today_too_many_args",
      "input": "timestamp>today('Europe/Berlin', 'extra')",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "accepts at most one argument"
      }
