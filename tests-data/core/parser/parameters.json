    {
      "name": "parameter_in_list",
      "input": "status in [$x, $y]",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "status",
          "operator": "in",
          "value": "",
          "value_type": null,
          "values": [
            {"name": "x", "positional": false},
            {"name": "y", "positional": false}
          ],
          "values_type": null,
          "values_types": ["parameter", "parameter"]
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "parameter_in_list_mixed",
      "input": "status in [active, $x, 200]",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "status",
          "operator": "in",
          "value": "",
          "value_type": null,
          "values": ["active", {"name": "x", "positional": false}, 200],
          "values_type": null,
          "values_types": ["column", "parameter", "int"]
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "parameter_in_function_ago",
      "input": "created=ago($duration)",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "created",
          "operator": "=",
          "value": {
            "name": "ago",
            "duration_args": [],
            "unit": "",
            "timezone": "",
            "parameter_args": [{"name": "duration", "positional": false}]
          },
          "value_type": "function"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "error_empty_param",
      "input": "status=$",
      "expected_result": "error",
      "expected_error": {
        "errno": 74,
        "message_contains": "empty parameter name"
      }
    },
    {
      "name": "error_empty_param_with_space",
      "input": "status=$ and x=1",
      "expected_result": "error",
      "expected_error": {
        "errno": 74,
        "message_contains": "empty parameter name"
      }
    },
    {
      "name": "error_invalid_positional",
      "input": "status=$1abc",
      "expected_result": "error",
      "expected_error": {
        "errno": 75,
        "message_contains": "invalid parameter name"
      }
    },
    {
      "name": "error_zero_positional",
      "input": "status=$0",
      "expected_result": "error",
      "expected_error": {
        "errno": 76,
        "message_contains": "positional parameters are 1-indexed"
      }
    }
