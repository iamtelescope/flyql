{
    "name": "flyql",
    "version": "0.0.54",
    "description": "A lightweight, injection-proof query language for multi-dialect SQL generation",
    "type": "module",
    "main": "./src/index.js",
    "exports": {
        ".": {
            "import": "./src/index.js"
        },
        "./core": {
            "import": "./src/core/index.js"
        },
        "./transformers": {
            "import": "./src/transformers/index.js"
        },
        "./renderers": {
            "import": "./src/renderers/index.js"
        },
        "./columns": {
            "import": "./src/columns/index.js"
        },
        "./columns/*": {
            "import": "./src/columns/*.js"
        },
        "./highlight": {
            "import": "./src/highlight.js"
        },
        "./tokenize": {
            "import": "./src/tokenize.js"
        },
        "./generators/clickhouse": {
            "import": "./src/generators/clickhouse/index.js"
        },
        "./generators/postgresql": {
            "import": "./src/generators/postgresql/index.js"
        },
        "./generators/starrocks": {
            "import": "./src/generators/starrocks/index.js"
        },
        "./matcher": {
            "import": "./src/matcher/index.js"
        }
    },
    "files": [
        "src/**/*.js",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "keywords": [
        "query",
        "parser",
        "ast",
        "sql",
        "filter",
        "javascript"
    ],
    "author": "Ilia (HumanUser) Khomutov",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/iamtelescope/flyql.git",
        "directory": "javascript/packages/flyql"
    },
    "bugs": {
        "url": "https://github.com/iamtelescope/flyql/issues"
    },
    "homepage": "https://docs.flyql.dev",
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "vitest": "^3.2.4"
    }
}
