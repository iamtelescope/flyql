{
  "version": "1.0",
  "description": "Temporal function SQL generation tests for PostgreSQL",
  "test_suite": "functions",
  "tests": [
    {
      "name": "ago_single_duration",
      "input": "ts>ago(1h)",
      "expected_result": "success",
      "expected_sql": "\"ts\" > (NOW() - INTERVAL '1 hours')"
    },
    {
      "name": "ago_compound_duration",
      "input": "ts>ago(1h30m)",
      "expected_result": "success",
      "expected_sql": "\"ts\" > (NOW() - INTERVAL '1 hours' - INTERVAL '30 minutes')"
    },
    {
      "name": "ago_weeks",
      "input": "ts>ago(2w)",
      "expected_result": "success",
      "expected_sql": "\"ts\" > (NOW() - INTERVAL '14 days')"
    },
    {
      "name": "now",
      "input": "ts>now()",
      "expected_result": "success",
      "expected_sql": "\"ts\" > NOW()"
    },
    {
      "name": "today_default_timezone",
      "input": "ts>today()",
      "expected_result": "success",
      "expected_sql": "\"ts\" > (NOW() AT TIME ZONE 'UTC')::date"
    },
    {
      "name": "today_explicit_timezone",
      "input": "ts>today('Europe/Berlin')",
      "expected_result": "success",
      "expected_sql": "\"ts\" > (NOW() AT TIME ZONE 'Europe/Berlin')::date"
    },
    {
      "name": "startof_day",
      "input": "ts>startOf('day')",
      "expected_result": "success",
      "expected_sql": "\"ts\" > date_trunc('day', NOW() AT TIME ZONE 'UTC') AT TIME ZONE 'UTC'"
    },
    {
      "name": "startof_week",
      "input": "ts>startOf('week')",
      "expected_result": "success",
      "expected_sql": "\"ts\" > date_trunc('week', NOW() AT TIME ZONE 'UTC') AT TIME ZONE 'UTC'"
    },
    {
      "name": "startof_month_with_timezone",
      "input": "ts>startOf('month', 'Asia/Tokyo')",
      "expected_result": "success",
      "expected_sql": "\"ts\" > date_trunc('month', NOW() AT TIME ZONE 'Asia/Tokyo') AT TIME ZONE 'Asia/Tokyo'"
    }
  ]
}
