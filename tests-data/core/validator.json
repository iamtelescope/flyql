{
  "version": "1.0",
  "description": "Shared validator test fixtures. Each test provides a query, column schema, and expected diagnostics. Custom transformers (takes_string_then_int, string_to_int, takes_float, takes_int, accepts_any, accepts_any_returning_array) must be registered per-language before running.",
  "test_suite": "validator",
  "custom_transformers": {
    "takes_string_then_int": {
      "input_type": "string",
      "output_type": "string",
      "arg_schema": [
        { "type": "string", "required": true },
        { "type": "int", "required": true }
      ]
    },
    "string_to_int": {
      "input_type": "string",
      "output_type": "int",
      "arg_schema": []
    },
    "takes_float": {
      "input_type": "string",
      "output_type": "string",
      "arg_schema": [
        { "type": "float", "required": true }
      ]
    },
    "takes_int": {
      "input_type": "string",
      "output_type": "string",
      "arg_schema": [
        { "type": "int", "required": true }
      ]
    },
    "accepts_any": {
      "input_type": "any",
      "output_type": "string",
      "arg_schema": []
    },
    "accepts_any_returning_array": {
      "input_type": "any",
      "output_type": "array",
      "arg_schema": []
    }
  },
  "tests": [
    {
      "name": "happy_path",
      "query": "name='X'",
      "columns": [{ "name": "name", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "unknown_column",
      "query": "hstt='X'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "range": [0, 4],
          "message_contains": "hstt"
        }
      ]
    },
    {
      "name": "unknown_column_case_insensitive_match",
      "query": "Host='X'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "duplicate_columns_first_wins",
      "query": "x|upper='V'",
      "columns": [
        { "name": "x", "type": "string" },
        { "name": "x", "type": "int" }
      ],
      "expected_diagnostics": []
    },
    {
      "name": "unknown_transformer",
      "query": "host|xyz='Y'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_transformer",
          "severity": "error",
          "range": [5, 8],
          "message_contains": "xyz"
        }
      ]
    },
    {
      "name": "arg_count_too_few",
      "query": "host|takes_string_then_int='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_count",
          "severity": "error",
          "message_contains": "expects"
        }
      ]
    },
    {
      "name": "arg_count_too_many",
      "query": "host|upper(\"extra\")='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_count",
          "severity": "error",
          "message_contains": "expects"
        }
      ]
    },
    {
      "name": "arg_type_mismatch",
      "query": "host|takes_string_then_int(\"a\", \"b\")='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_type",
          "severity": "error",
          "message_contains": "argument 2"
        }
      ]
    },
    {
      "name": "arg_type_int_widens_to_float",
      "query": "host|takes_float(3)='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "arg_type_float_does_not_match_int",
      "query": "host|takes_int(3.5)='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "arg_type",
          "severity": "error"
        }
      ]
    },
    {
      "name": "chain_type_column_to_first_transformer",
      "query": "count|upper='V'",
      "columns": [{ "name": "count", "type": "int" }],
      "expected_diagnostics": [
        {
          "code": "chain_type",
          "severity": "error",
          "message_contains": "upper"
        }
      ]
    },
    {
      "name": "chain_type_between_transformers",
      "query": "host|string_to_int|upper='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "chain_type",
          "severity": "error",
          "message_contains": "upper"
        }
      ]
    },
    {
      "name": "chain_type_cascades_after_error",
      "query": "count|len|upper='V'",
      "columns": [{ "name": "count", "type": "int" }],
      "expected_diagnostics": [
        { "code": "chain_type", "severity": "error" },
        { "code": "chain_type", "severity": "error" }
      ]
    },
    {
      "name": "chain_type_breaks_at_unknown_transformer",
      "query": "host|xyz|upper='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        { "code": "unknown_transformer", "severity": "error" }
      ],
      "absent_codes": ["chain_type"]
    },
    {
      "name": "chain_type_skipped_when_column_unknown",
      "query": "missing|upper='V'",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error" }
      ],
      "absent_codes": ["chain_type"]
    },
    {
      "name": "chain_type_fires_when_column_type_is_not_transformer_input",
      "query": "m|upper='V'",
      "columns": [{ "name": "m", "type": "map" }],
      "expected_diagnostics": [
        { "code": "chain_type", "severity": "error", "message_contains": "upper" }
      ]
    },
    {
      "name": "any_input_accepts_string_column",
      "query": "host|accepts_any='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "any_input_accepts_non_string_column",
      "query": "count|accepts_any='V'",
      "columns": [{ "name": "count", "type": "int" }],
      "expected_diagnostics": [],
      "absent_codes": ["chain_type"]
    },
    {
      "name": "chain_after_any_input_returning_array_errors_on_upper",
      "query": "count|accepts_any_returning_array|upper='V'",
      "columns": [{ "name": "count", "type": "int" }],
      "expected_diagnostics": [
        { "code": "chain_type", "severity": "error", "message_contains": "upper" }
      ]
    },
    {
      "name": "any_input_on_unknown_column_still_skips_chain_type",
      "query": "missing|accepts_any='V'",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error" }
      ],
      "absent_codes": ["chain_type"]
    },
    {
      "name": "multiple_expressions",
      "query": "hstt='A' and othr='B'",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error", "message_contains": "hstt" },
        { "code": "unknown_column", "severity": "error", "message_contains": "othr" }
      ]
    },
    {
      "name": "or_and_not_expressions",
      "query": "not (a=1 or b=2)",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error", "message_contains": "a" },
        { "code": "unknown_column", "severity": "error", "message_contains": "b" }
      ]
    },
    {
      "name": "truthy_known",
      "query": "host",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "truthy_unknown",
      "query": "host",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error" }
      ]
    },
    {
      "name": "in_known",
      "query": "status in [200, 404]",
      "columns": [{ "name": "status", "type": "int" }],
      "expected_diagnostics": []
    },
    {
      "name": "in_unknown",
      "query": "status in [200, 404]",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error" }
      ]
    },
    {
      "name": "mixed_diagnostics",
      "query": "unknown_col|xyz='V'",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error" },
        { "code": "unknown_transformer", "severity": "error" }
      ]
    },
    {
      "name": "default_registry_fallback",
      "query": "host|upper='V'",
      "columns": [{ "name": "host", "type": "string" }],
      "use_default_registry": true,
      "expected_diagnostics": []
    },
    {
      "name": "none_ast",
      "query": null,
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": []
    },
    {
      "name": "column_value_known",
      "query": "field=host",
      "columns": [
        { "name": "field", "type": "string" },
        { "name": "host", "type": "string" }
      ],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "column_value_unknown",
      "query": "field=nonexistent",
      "columns": [{ "name": "field", "type": "string" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column_value",
          "severity": "error",
          "message_contains": "nonexistent"
        }
      ]
    },
    {
      "name": "column_value_case_insensitive",
      "query": "field=Host",
      "columns": [
        { "name": "field", "type": "string" },
        { "name": "host", "type": "string" }
      ],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "column_value_quoted_string_no_warning",
      "query": "field='somevalue'",
      "columns": [{ "name": "field", "type": "string" }],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "column_value_numeric_no_warning",
      "query": "field=42",
      "columns": [{ "name": "field", "type": "string" }],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "column_value_in_list_mixed",
      "query": "field in [known, 'str', unknown]",
      "columns": [
        { "name": "field", "type": "string" },
        { "name": "known", "type": "string" }
      ],
      "expected_diagnostics": [
        {
          "code": "unknown_column_value",
          "severity": "error",
          "message_contains": "unknown"
        }
      ]
    },
    {
      "name": "column_value_both_sides_unknown",
      "query": "missing=also_missing",
      "columns": [],
      "expected_diagnostics": [
        { "code": "unknown_column", "severity": "error", "message_contains": "missing" },
        { "code": "unknown_column_value", "severity": "error", "message_contains": "also_missing" }
      ]
    },
    {
      "name": "column_value_in_boolean_expr",
      "query": "a=b and c=d",
      "columns": [
        { "name": "a", "type": "string" },
        { "name": "b", "type": "string" },
        { "name": "c", "type": "string" }
      ],
      "expected_diagnostics": [
        { "code": "unknown_column_value", "severity": "error", "message_contains": "d" }
      ]
    },
    {
      "name": "column_value_truthy_no_warning",
      "query": "host",
      "columns": [{ "name": "host", "type": "string" }],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "date_column_invalid_string",
      "query": "event_day > 'not-a-date'",
      "columns": [{ "name": "event_day", "type": "date" }],
      "expected_diagnostics": [
        {
          "code": "invalid_datetime_literal",
          "severity": "warning",
          "message_contains": "not-a-date"
        }
      ]
    },
    {
      "name": "date_column_valid_string",
      "query": "event_day > '2026-04-06'",
      "columns": [{ "name": "event_day", "type": "date" }],
      "expected_diagnostics": [],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "datetime_column_valid_variant_T",
      "query": "ts > '2026-04-06T21:00:00Z'",
      "columns": [{ "name": "ts", "type": "datetime" }],
      "expected_diagnostics": [],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "datetime_column_valid_variant_space",
      "query": "ts > '2026-04-06 21:00:00Z'",
      "columns": [{ "name": "ts", "type": "datetime" }],
      "expected_diagnostics": [],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "datetime_column_invalid_string",
      "query": "ts > 'garbage'",
      "columns": [{ "name": "ts", "type": "datetime" }],
      "expected_diagnostics": [
        {
          "code": "invalid_datetime_literal",
          "severity": "warning",
          "message_contains": "garbage"
        }
      ]
    },
    {
      "name": "datetime_column_valid_with_offset",
      "query": "ts > '2026-04-06T21:00:00+02:00'",
      "columns": [{ "name": "ts", "type": "datetime" }],
      "expected_diagnostics": [],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "non_date_column_string_no_warning",
      "query": "name > 'garbage'",
      "columns": [{ "name": "name", "type": "string" }],
      "expected_diagnostics": [],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "date_column_invalid_column_ref_suppresses_datetime_literal",
      "query": "event_day > foo+bar",
      "columns": [{ "name": "event_day", "type": "date" }],
      "expected_diagnostics": [
        {
          "code": "invalid_column_value",
          "severity": "error",
          "message_contains": "foo+bar"
        }
      ],
      "absent_codes": ["invalid_datetime_literal"]
    },
    {
      "name": "datetime_column_invalid_calendar_month",
      "query": "ts > '2026-13-01'",
      "columns": [{ "name": "ts", "type": "datetime" }],
      "expected_diagnostics": [
        {
          "code": "invalid_datetime_literal",
          "severity": "warning",
          "message_contains": "2026-13-01"
        }
      ]
    },
    {
      "name": "date_column_invalid_calendar_day",
      "query": "event_day > '2026-02-31'",
      "columns": [{ "name": "event_day", "type": "date" }],
      "expected_diagnostics": [
        {
          "code": "invalid_datetime_literal",
          "severity": "warning",
          "message_contains": "2026-02-31"
        }
      ]
    },
    {
      "name": "permissive_lhs_json_no_children",
      "query": "body.message='x'",
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_lhs_map_no_children",
      "query": "body.message='x'",
      "columns": [{ "name": "body", "type": "map" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_lhs_jsonstring_no_children",
      "query": "body.message='x'",
      "columns": [{ "name": "body", "type": "jsonstring" }],
      "expected_diagnostics": []
    },
    {
      "name": "permissive_lhs_unknown_no_children",
      "query": "body.message='x'",
      "columns": [{ "name": "body", "type": "unknown" }],
      "expected_diagnostics": []
    },
    {
      "name": "strict_lhs_struct_errors",
      "query": "body.message='x'",
      "columns": [{ "name": "body", "type": "struct" }],
      "expected_diagnostics": [
        {
          "code": "unknown_column",
          "severity": "error",
          "message_contains": "message"
        }
      ]
    },
    {
      "name": "permissive_value_side_column_ref",
      "query": "host=body.message",
      "columns": [
        { "name": "host", "type": "string" },
        { "name": "body", "type": "json" }
      ],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "permissive_in_list_value_side",
      "query": "host in [body.foo, body.bar]",
      "columns": [
        { "name": "host", "type": "string" },
        { "name": "body", "type": "json" }
      ],
      "expected_diagnostics": [],
      "absent_codes": ["unknown_column_value"]
    },
    {
      "name": "strict_value_side_struct_errors",
      "query": "host=body.x",
      "columns": [
        { "name": "host", "type": "string" },
        { "name": "body", "type": "struct" }
      ],
      "expected_diagnostics": [
        {
          "code": "unknown_column_value",
          "severity": "error",
          "message_contains": "body.x"
        }
      ]
    },
    {
      "name": "permissive_lhs_then_transformer_no_chain",
      "query": "body.message|upper='x'",
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": [],
      "absent_codes": ["chain_type"]
    },
    {
      "name": "permissive_lhs_multi_transformer_chain",
      "query": "body.foo|len|upper='x'",
      "columns": [{ "name": "body", "type": "json" }],
      "expected_diagnostics": [
        {
          "code": "chain_type",
          "severity": "error",
          "range": [13, 18],
          "message_contains": "upper"
        }
      ]
    }
  ]
}
