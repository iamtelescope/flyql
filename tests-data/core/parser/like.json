{
  "version": "1.0",
  "description": "LIKE/ILIKE operator parser test cases",
  "test_suite": "like",
  "tests": [
    {
      "name": "like_suffix_wildcard",
      "input": "key like 'hello%'",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "key",
          "operator": "like",
          "value": "hello%",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "like_prefix_wildcard",
      "input": "key like '%world'",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "key",
          "operator": "like",
          "value": "%world",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
