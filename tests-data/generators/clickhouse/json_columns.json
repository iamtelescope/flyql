{
  "version": "1.0",
  "description": "JSON columns ClickHouse generator test cases",
  "test_suite": "json_columns",
  "tests": [
    {
      "name": "native_json_simple_path",
      "input": "new_json.name='test'",
      "expected_result": "success",
      "expected_sql": "new_json.`name` = 'test'"
    },
    {
      "name": "native_json_nested_path",
      "input": "new_json.user.name='john'",
      "expected_result": "success",
      "expected_sql": "new_json.`user`.`name` = 'john'"
    },
    {
      "name": "native_json_number_value",
      "input": "new_json.age=25",
      "expected_result": "success",
      "expected_sql": "new_json.`age` = 25"
    },
    {
      "name": "native_json_underscore_column",
      "input": "new_json.column_name='test'",
      "expected_result": "success",
      "expected_sql": "new_json.`column_name` = 'test'"
    },
    {
      "name": "native_json_hyphen_column",
      "input": "new_json.column-name='test'",
      "expected_result": "success",
      "expected_sql": "new_json.`column-name` = 'test'"
    },
    {
      "name": "native_json_dot_in_column",
      "input": "new_json.'column.subcolumn'='test'",
      "expected_result": "success",
      "expected_sql": "new_json.`column.subcolumn` = 'test'"
    },
    {
      "name": "native_json_not_equals",
      "input": "new_json.status!='active'",
      "expected_result": "success",
      "expected_sql": "new_json.`status` != 'active'"
    },
    {
      "name": "native_json_greater_than",
      "input": "new_json.count>100",
      "expected_result": "success",
      "expected_sql": "new_json.`count` > 100"
    },
    {
      "name": "jsonstring_simple_path",
      "input": "json_column.name='test'",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'name') = 'String', equals(JSONExtractString(json_column, 'name'), 'test'),0)"
    },
    {
      "name": "jsonstring_nested_path",
      "input": "json_column.user.name='john'",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'user', 'name') = 'String', equals(JSONExtractString(json_column, 'user', 'name'), 'john'),0)"
    },
    {
      "name": "jsonstring_number_value",
      "input": "json_column.age=25",
      "expected_result": "success",
      "expected_sql_contains": [
        "JSONExtractInt",
        "JSONExtractFloat",
        "JSONExtractBool"
      ]
    },
    {
      "name": "jsonstring_not_equals",
      "input": "json_column.status!='active'",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'status') AND multiIf(JSONType(json_column, 'status') = 'String', notEquals(JSONExtractString(json_column, 'status'), 'active'),0))"
    },
    {
      "name": "jsonstring_regex_match",
      "input": "json_column.message~'error.*'",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'message') = 'String', match(JSONExtractString(json_column, 'message'), 'error.*'),0)"
    },
    {
      "name": "jsonstring_regex_not_match",
      "input": "json_column.message!~'error.*'",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'message') AND NOT multiIf(JSONType(json_column, 'message') = 'String', match(JSONExtractString(json_column, 'message'), 'error.*'),1))"
    },
    {
      "name": "native_json_like",
      "input": "new_json.name like 'john%'",
      "expected_result": "success",
      "expected_sql": "new_json.`name` LIKE 'john%'"
    },
    {
      "name": "native_json_not_like",
      "input": "new_json.name not like 'john%'",
      "expected_result": "success",
      "expected_sql": "new_json.`name` NOT LIKE 'john%'"
    },
    {
      "name": "native_json_ilike",
      "input": "new_json.name ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "new_json.`name` ILIKE 'John%'"
    },
    {
      "name": "native_json_not_ilike",
      "input": "new_json.name not ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "new_json.`name` NOT ILIKE 'John%'"
    },
    {
      "name": "jsonstring_like",
      "input": "json_column.name like 'john%'",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'name') = 'String', like(JSONExtractString(json_column, 'name'), 'john%'),0)"
    },
    {
      "name": "jsonstring_not_like",
      "input": "json_column.name not like 'john%'",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'name') AND multiIf(JSONType(json_column, 'name') = 'String', notLike(JSONExtractString(json_column, 'name'), 'john%'),0))"
    },
    {
      "name": "jsonstring_ilike",
      "input": "json_column.name ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'name') = 'String', ilike(JSONExtractString(json_column, 'name'), 'John%'),0)"
    },
    {
      "name": "jsonstring_not_ilike",
      "input": "json_column.name not ilike 'John%'",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'name') AND multiIf(JSONType(json_column, 'name') = 'String', notILike(JSONExtractString(json_column, 'name'), 'John%'),0))"
    },
    {
      "name": "native_json_has",
      "input": "new_json.name has 'john'",
      "expected_result": "success",
      "expected_sql": "position(toString(new_json.`name`), 'john') > 0"
    },
    {
      "name": "native_json_not_has",
      "input": "new_json.name not has 'john'",
      "expected_result": "success",
      "expected_sql": "(new_json.`name` IS NOT NULL AND position(toString(new_json.`name`), 'john') = 0)"
    },
    {
      "name": "native_json_truthy",
      "input": "new_json.name",
      "expected_result": "success",
      "expected_sql": "(new_json.`name` IS NOT NULL)"
    },
    {
      "name": "native_json_falsy",
      "input": "not new_json.name",
      "expected_result": "success",
      "expected_sql": "(new_json.`name` IS NULL)"
    },
    {
      "name": "native_json_in_strings",
      "input": "new_json.name in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "toString(new_json.`name`) IN ('a', 'b')"
    },
    {
      "name": "native_json_not_in_strings",
      "input": "new_json.name not in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "(new_json.`name` IS NOT NULL AND toString(new_json.`name`) NOT IN ('a', 'b'))"
    },
    {
      "name": "native_json_lt",
      "input": "new_json.count < 100",
      "expected_result": "success",
      "expected_sql": "new_json.`count` < 100"
    },
    {
      "name": "native_json_ge",
      "input": "new_json.count >= 100",
      "expected_result": "success",
      "expected_sql": "new_json.`count` >= 100"
    },
    {
      "name": "native_json_le",
      "input": "new_json.count <= 100",
      "expected_result": "success",
      "expected_sql": "new_json.`count` <= 100"
    },
    {
      "name": "jsonstring_has",
      "input": "json_column.name has 'john'",
      "expected_result": "success",
      "expected_sql": "position(JSONExtractString(json_column, 'name'), 'john') > 0"
    },
    {
      "name": "jsonstring_not_has",
      "input": "json_column.name not has 'john'",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'name') AND position(JSONExtractString(json_column, 'name'), 'john') = 0)"
    },
    {
      "name": "jsonstring_truthy",
      "input": "json_column.name",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'name') AND JSONExtractString(json_column, 'name') != '')"
    },
    {
      "name": "jsonstring_falsy",
      "input": "not json_column.name",
      "expected_result": "success",
      "expected_sql": "(NOT JSONHas(json_column, 'name') OR JSONExtractString(json_column, 'name') = '')"
    },
    {
      "name": "jsonstring_in_strings",
      "input": "json_column.name in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'name') = 'String', JSONExtractString(json_column, 'name') IN ('a', 'b'),0)"
    },
    {
      "name": "jsonstring_not_in_strings",
      "input": "json_column.name not in ['a', 'b']",
      "expected_result": "success",
      "expected_sql": "(JSONHas(json_column, 'name') AND NOT multiIf(JSONType(json_column, 'name') = 'String', JSONExtractString(json_column, 'name') IN ('a', 'b'),1))"
    },
    {
      "name": "jsonstring_in_numeric",
      "input": "json_column.count in [1, 2, 3]",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'count') = 'String', JSONExtractString(json_column, 'count') IN (1, 2, 3),JSONType(json_column, 'count') = 'Int64', JSONExtractInt(json_column, 'count') IN (1, 2, 3),JSONType(json_column, 'count') = 'Double', JSONExtractFloat(json_column, 'count') IN (1, 2, 3),JSONType(json_column, 'count') = 'Bool', JSONExtractBool(json_column, 'count') IN (1, 2, 3),0)"
    },
    {
      "name": "jsonstring_lt",
      "input": "json_column.count < 100",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'count') = 'String', less(JSONExtractString(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Int64', less(JSONExtractInt(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Double', less(JSONExtractFloat(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Bool', less(JSONExtractBool(json_column, 'count'), 100),0)"
    },
    {
      "name": "jsonstring_ge",
      "input": "json_column.count >= 100",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'count') = 'String', greaterOrEquals(JSONExtractString(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Int64', greaterOrEquals(JSONExtractInt(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Double', greaterOrEquals(JSONExtractFloat(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Bool', greaterOrEquals(JSONExtractBool(json_column, 'count'), 100),0)"
    },
    {
      "name": "jsonstring_le",
      "input": "json_column.count <= 100",
      "expected_result": "success",
      "expected_sql": "multiIf(JSONType(json_column, 'count') = 'String', lessOrEquals(JSONExtractString(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Int64', lessOrEquals(JSONExtractInt(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Double', lessOrEquals(JSONExtractFloat(json_column, 'count'), 100),JSONType(json_column, 'count') = 'Bool', lessOrEquals(JSONExtractBool(json_column, 'count'), 100),0)"
    },
    {
      "name": "native_json_regex_match",
      "input": "new_json.region~'eu.*'",
      "expected_result": "success",
      "expected_sql": "match(toString(new_json.`region`), 'eu.*')"
    },
    {
      "name": "native_json_not_regex_match",
      "input": "new_json.region!~'eu.*'",
      "expected_result": "success",
      "expected_sql": "(new_json.`region` IS NOT NULL AND NOT match(toString(new_json.`region`), 'eu.*'))"
    }
  ]
}
