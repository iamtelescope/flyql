{
  "version": "1.0",
  "description": "Map and Array columns Starrocks generator test cases",
  "test_suite": "map_array",
  "tests": [
    {
      "name": "map_simple_key",
      "input": "metadata.key1='value1'",
      "expected_result": "success",
      "expected_sql": "`metadata`['key1'] = 'value1'"
    },
    {
      "name": "map_dot_in_key_key",
      "input": "metadata.'nested.key'='value'",
      "expected_result": "success",
      "expected_sql": "`metadata`['nested.key'] = 'value'"
    },
    {
      "name": "map_nested_key",
      "input": "metadata.nested.key='value'",
      "expected_result": "success",
      "expected_sql": "`metadata`['nested']['key'] = 'value'"
    },
    {
      "name": "map_not_equals",
      "input": "metadata.key1!='value1'",
      "expected_result": "success",
      "expected_sql": "`metadata`['key1'] != 'value1'"
    },
    {
      "name": "map_regex_match",
      "input": "metadata.pattern~'test.*'",
      "expected_result": "success",
      "expected_sql": "`metadata`['pattern'] regexp 'test.*'"
    },
    {
      "name": "map_regex_not_match",
      "input": "metadata.pattern!~'test.*'",
      "expected_result": "success",
      "expected_sql": "`metadata`['pattern'] NOT regexp 'test.*'"
    },
    {
      "name": "array_index_0",
      "input": "tags.0='first'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] = 'first'"
    },
    {
      "name": "array_index_1",
      "input": "tags.1='second'",
      "expected_result": "success",
      "expected_sql": "`tags`[2] = 'second'"
    },
    {
      "name": "array_not_equals",
      "input": "tags.0!='excluded'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] != 'excluded'"
    },
    {
      "name": "array_regex_match",
      "input": "tags.0~'tag.*'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] regexp 'tag.*'"
    },
    {
      "name": "map_key_with_single_quote",
      "input": "metadata.\"key'quote\"='value'",
      "expected_result": "success",
      "expected_sql": "`metadata`['key\\'quote'] = 'value'"
    },
    {
      "name": "map_key_with_backslash",
      "input": "metadata.\"key\\\\slash\"='value'",
      "expected_result": "success",
      "expected_sql": "`metadata`['key\\\\slash'] = 'value'"
    },
    {
      "name": "map_like",
      "input": "metadata.region like 'us-%'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] LIKE 'us-%'"
    },
    {
      "name": "map_not_like",
      "input": "metadata.region not like 'us-%'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] NOT LIKE 'us-%'"
    },
    {
      "name": "map_ilike",
      "input": "metadata.region ilike 'US-%'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] ILIKE 'US-%'"
    },
    {
      "name": "map_not_ilike",
      "input": "metadata.region not ilike 'US-%'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] NOT ILIKE 'US-%'"
    },
    {
      "name": "array_like",
      "input": "tags.0 like 'w%'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] LIKE 'w%'"
    },
    {
      "name": "array_not_like",
      "input": "tags.0 not like 'w%'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] NOT LIKE 'w%'"
    },
    {
      "name": "array_ilike",
      "input": "tags.0 ilike 'W%'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] ILIKE 'W%'"
    },
    {
      "name": "array_not_ilike",
      "input": "tags.0 not ilike 'W%'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] NOT ILIKE 'W%'"
    },
    {
      "name": "map_has",
      "input": "metadata.region has 'us'",
      "expected_result": "success",
      "expected_sql": "INSTR(`metadata`['region'], 'us') > 0"
    },
    {
      "name": "map_not_has",
      "input": "metadata.region not has 'us'",
      "expected_result": "success",
      "expected_sql": "INSTR(`metadata`['region'], 'us') = 0"
    },
    {
      "name": "map_truthy",
      "input": "metadata.region",
      "expected_result": "success",
      "expected_sql": "(element_at(`metadata`, 'region') IS NOT NULL AND `metadata`['region'] != '')"
    },
    {
      "name": "map_falsy",
      "input": "not metadata.region",
      "expected_result": "success",
      "expected_sql": "(element_at(`metadata`, 'region') IS NULL OR `metadata`['region'] = '')"
    },
    {
      "name": "map_in",
      "input": "metadata.region in ['us', 'eu']",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] IN ('us', 'eu')"
    },
    {
      "name": "map_not_in",
      "input": "metadata.region not in ['us', 'eu']",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] NOT IN ('us', 'eu')"
    },
    {
      "name": "map_gt",
      "input": "metadata.region > 'a'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] > 'a'"
    },
    {
      "name": "map_lt",
      "input": "metadata.region < 'z'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] < 'z'"
    },
    {
      "name": "map_ge",
      "input": "metadata.region >= 'a'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] >= 'a'"
    },
    {
      "name": "map_le",
      "input": "metadata.region <= 'z'",
      "expected_result": "success",
      "expected_sql": "`metadata`['region'] <= 'z'"
    },
    {
      "name": "array_has",
      "input": "tags.0 has 'web'",
      "expected_result": "success",
      "expected_sql": "INSTR(`tags`[1], 'web') > 0"
    },
    {
      "name": "array_not_has",
      "input": "tags.0 not has 'web'",
      "expected_result": "success",
      "expected_sql": "INSTR(`tags`[1], 'web') = 0"
    },
    {
      "name": "array_truthy",
      "input": "tags.0",
      "expected_result": "success",
      "expected_sql": "(array_length(`tags`) >= 1 AND `tags`[1] != '')"
    },
    {
      "name": "array_falsy",
      "input": "not tags.0",
      "expected_result": "success",
      "expected_sql": "(array_length(`tags`) < 1 OR `tags`[1] = '')"
    },
    {
      "name": "array_in",
      "input": "tags.0 in ['web', 'api']",
      "expected_result": "success",
      "expected_sql": "`tags`[1] IN ('web', 'api')"
    },
    {
      "name": "array_not_in",
      "input": "tags.0 not in ['web', 'api']",
      "expected_result": "success",
      "expected_sql": "`tags`[1] NOT IN ('web', 'api')"
    },
    {
      "name": "array_gt",
      "input": "tags.0 > 'a'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] > 'a'"
    },
    {
      "name": "array_lt",
      "input": "tags.0 < 'z'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] < 'z'"
    },
    {
      "name": "array_ge",
      "input": "tags.0 >= 'a'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] >= 'a'"
    },
    {
      "name": "array_le",
      "input": "tags.0 <= 'z'",
      "expected_result": "success",
      "expected_sql": "`tags`[1] <= 'z'"
    }
  ]
}
