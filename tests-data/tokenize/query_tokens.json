{
    "version": "1.0",
    "description": "Tokenizer test cases for cross-language parity (query mode). ASCII-only; non-ASCII inputs out of scope. Fixtures hand-authored from the parser oracle (not derived from tokenize() output). Covers: flyqlKey, flyqlOperator, number, string, flyqlBoolean, flyqlNull, flyqlColumn, flyqlError, plus optional space, flyqlPipe, flyqlTransformer. Exercises all five VALUE upgrade branches and pins rejection of Infinity/NaN/hex by the canonical numeric regex.",
    "test_suite": "tokenize_query",
    "ascii_only": true,
    "coverage": [
        "flyqlKey",
        "flyqlOperator",
        "number",
        "string",
        "flyqlBoolean",
        "flyqlNull",
        "flyqlColumn",
        "flyqlError"
    ],
    "tests": [
        {
            "name": "empty",
            "input": "",
            "expected_tokens": []
        },
        {
            "name": "key_number",
            "input": "status=200",
            "expected_tokens": [
                { "text": "status", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "200", "type": "number", "start": 7, "end": 10 }
            ]
        },
        {
            "name": "key_string_single_quote",
            "input": "status='ok'",
            "expected_tokens": [
                { "text": "status", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "'ok'", "type": "string", "start": 7, "end": 11 }
            ]
        },
        {
            "name": "key_string_double_quote",
            "input": "status=\"ok\"",
            "expected_tokens": [
                { "text": "status", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "\"ok\"", "type": "string", "start": 7, "end": 11 }
            ]
        },
        {
            "name": "key_column",
            "input": "status=alice",
            "expected_tokens": [
                { "text": "status", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "alice", "type": "flyqlColumn", "start": 7, "end": 12 }
            ]
        },
        {
            "name": "key_boolean_true",
            "input": "active=true",
            "expected_tokens": [
                { "text": "active", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "true", "type": "flyqlBoolean", "start": 7, "end": 11 }
            ]
        },
        {
            "name": "key_boolean_false",
            "input": "active=false",
            "expected_tokens": [
                { "text": "active", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "false", "type": "flyqlBoolean", "start": 7, "end": 12 }
            ]
        },
        {
            "name": "key_null",
            "input": "deleted=null",
            "expected_tokens": [
                { "text": "deleted", "type": "flyqlKey", "start": 0, "end": 7 },
                { "text": "=", "type": "flyqlOperator", "start": 7, "end": 8 },
                { "text": "null", "type": "flyqlNull", "start": 8, "end": 12 }
            ]
        },
        {
            "name": "key_number_negative",
            "input": "count=-42",
            "expected_tokens": [
                { "text": "count", "type": "flyqlKey", "start": 0, "end": 5 },
                { "text": "=", "type": "flyqlOperator", "start": 5, "end": 6 },
                { "text": "-42", "type": "number", "start": 6, "end": 9 }
            ]
        },
        {
            "name": "key_number_decimal",
            "input": "price=3.14",
            "expected_tokens": [
                { "text": "price", "type": "flyqlKey", "start": 0, "end": 5 },
                { "text": "=", "type": "flyqlOperator", "start": 5, "end": 6 },
                { "text": "3.14", "type": "number", "start": 6, "end": 10 }
            ]
        },
        {
            "name": "key_number_scientific",
            "input": "scale=1e5",
            "expected_tokens": [
                { "text": "scale", "type": "flyqlKey", "start": 0, "end": 5 },
                { "text": "=", "type": "flyqlOperator", "start": 5, "end": 6 },
                { "text": "1e5", "type": "number", "start": 6, "end": 9 }
            ]
        },
        {
            "name": "key_number_rejected_infinity",
            "input": "val=Infinity",
            "expected_tokens": [
                { "text": "val", "type": "flyqlKey", "start": 0, "end": 3 },
                { "text": "=", "type": "flyqlOperator", "start": 3, "end": 4 },
                { "text": "Infinity", "type": "flyqlColumn", "start": 4, "end": 12 }
            ]
        },
        {
            "name": "key_number_rejected_nan",
            "input": "val=NaN",
            "expected_tokens": [
                { "text": "val", "type": "flyqlKey", "start": 0, "end": 3 },
                { "text": "=", "type": "flyqlOperator", "start": 3, "end": 4 },
                { "text": "NaN", "type": "flyqlColumn", "start": 4, "end": 7 }
            ]
        },
        {
            "name": "key_number_rejected_hex",
            "input": "val=0x1F",
            "expected_tokens": [
                { "text": "val", "type": "flyqlKey", "start": 0, "end": 3 },
                { "text": "=", "type": "flyqlOperator", "start": 3, "end": 4 },
                { "text": "0x1F", "type": "flyqlColumn", "start": 4, "end": 8 }
            ]
        },
        {
            "name": "compound_and",
            "input": "status=200 and region='us-east'",
            "expected_tokens": [
                { "text": "status", "type": "flyqlKey", "start": 0, "end": 6 },
                { "text": "=", "type": "flyqlOperator", "start": 6, "end": 7 },
                { "text": "200", "type": "number", "start": 7, "end": 10 },
                { "text": " ", "type": "space", "start": 10, "end": 11 },
                { "text": "and", "type": "flyqlOperator", "start": 11, "end": 14 },
                { "text": " ", "type": "space", "start": 14, "end": 15 },
                { "text": "region", "type": "flyqlKey", "start": 15, "end": 21 },
                { "text": "=", "type": "flyqlOperator", "start": 21, "end": 22 },
                { "text": "'us-east'", "type": "string", "start": 22, "end": 31 }
            ]
        },
        {
            "name": "json_path_key",
            "input": "meta.region='us-east'",
            "expected_tokens": [
                { "text": "meta.region", "type": "flyqlKey", "start": 0, "end": 11 },
                { "text": "=", "type": "flyqlOperator", "start": 11, "end": 12 },
                { "text": "'us-east'", "type": "string", "start": 12, "end": 21 }
            ]
        },
        {
            "name": "transformer_with_arg",
            "input": "msg|upper='X'",
            "expected_tokens": [
                { "text": "msg", "type": "flyqlKey", "start": 0, "end": 3 },
                { "text": "|", "type": "flyqlPipe", "start": 3, "end": 4 },
                { "text": "upper", "type": "flyqlTransformer", "start": 4, "end": 9 },
                { "text": "=", "type": "flyqlOperator", "start": 9, "end": 10 },
                { "text": "'X'", "type": "string", "start": 10, "end": 13 }
            ]
        },
        {
            "name": "error_trailing",
            "input": "x!y",
            "expected_tokens": [
                { "text": "x", "type": "flyqlKey", "start": 0, "end": 1 },
                { "text": "!", "type": "flyqlOperator", "start": 1, "end": 2 },
                { "text": "y", "type": "flyqlError", "start": 2, "end": 3 }
            ]
        },
        {
            "name": "error_only",
            "input": "#bad",
            "expected_tokens": [
                { "text": "#bad", "type": "flyqlError", "start": 0, "end": 4 }
            ]
        }
    ]
}
