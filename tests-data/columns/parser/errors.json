{
  "version": "1.0",
  "description": "Error handling tests",
  "test_suite": "errors",
  "tests": [
    {
      "name": "invalid_character_at_start",
      "input": "$message",
      "expected_result": "error",
      "expected_error": {
        "errno": 2,
        "message_contains": ""
      }
    },
    {
      "name": "invalid_character_in_column",
      "input": "mes$sage",
      "expected_result": "error",
      "expected_error": {
        "errno": 6,
        "message_contains": ""
      }
    },
    {
      "name": "incomplete_transformer",
      "input": "message|",
      "capabilities": {
        "transformers": true
      },
      "expected_result": "error",
      "expected_error": {
        "errno": 7,
        "message_contains": ""
      }
    },
    {
      "name": "unclosed_transformer_args",
      "input": "message|chars(",
      "capabilities": {
        "transformers": true
      },
      "expected_result": "error",
      "expected_error": {
        "errno": 16,
        "message_contains": ""
      }
    },
    {
      "name": "unclosed_single_quote",
      "input": "message|split('tab)",
      "capabilities": {
        "transformers": true
      },
      "expected_result": "error",
      "expected_error": {
        "errno": 12,
        "message_contains": ""
      }
    },
    {
      "name": "unclosed_double_quote",
      "input": "message|split(\"tab)",
      "capabilities": {
        "transformers": true
      },
      "expected_result": "error",
      "expected_error": {
        "errno": 12,
        "message_contains": ""
      }
    },
    {
      "name": "incomplete_alias_operator",
      "input": "message a",
      "expected_result": "error",
      "expected_error": {
        "errno": 14,
        "message_contains": ""
      }
    },
    {
      "name": "incomplete_alias",
      "input": "message as",
      "expected_result": "error",
      "expected_error": {
        "errno": 14,
        "message_contains": ""
      }
    },
    {
      "name": "invalid_alias_operator",
      "input": "message ax msg",
      "expected_result": "error",
      "expected_error": {
        "errno": 4,
        "message_contains": ""
      }
    },
    {
      "name": "transformers_not_enabled",
      "input": "message|upper",
      "expected_result": "error",
      "expected_error": {
        "errno": 17,
        "message_contains": ""
      }
    }
  ]
}
