{
  "version": "1.0",
  "description": "FlyQL not operator test cases - unary negation",
  "test_suite": "not",
  "tests": [
    {
      "name": "not_truthy",
      "input": "not active",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "negated": true,
        "expression": {
          "key": "active",
          "operator": "truthy",
          "value": "",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "not_comparison",
      "input": "not status=200",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "negated": true,
        "expression": {
          "key": "status",
          "operator": "=",
          "value": 200.0,
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "not_grouped_and",
      "input": "not (a=1 and b=2)",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "and",
        "negated": true,
        "expression": null,
        "left": {
          "bool_operator": "",
          "negated": false,
          "expression": {
            "key": "a",
            "operator": "=",
            "value": 1.0,
            "value_type": "number"
          },
          "left": null,
          "right": null
        },
        "right": {
          "bool_operator": "",
          "negated": false,
          "expression": {
            "key": "b",
            "operator": "=",
            "value": 2.0,
            "value_type": "number"
          },
          "left": null,
          "right": null
        }
      }
    },
    {
      "name": "not_grouped_or",
      "input": "not (a=1 or b=2)",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "or",
