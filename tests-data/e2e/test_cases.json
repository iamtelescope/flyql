{
  "version": "1.0",
  "description": "E2E test cases shared across databases. Data: 6 rows with id 1-6.",
  "tests": [
    {
      "name": "string_equals",
      "flyql": "message='hello'",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_not_equals",
      "flyql": "message!='hello'",
      "expected_ids": [2, 3, 4, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_like_pattern",
      "flyql": "message='hello*'",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_regex_match",
      "flyql": "message~'hello.*'",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "string_regex_not_match",
      "flyql": "message!~'hello.*'",
      "expected_ids": [2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_equals",
      "flyql": "count=42",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_greater_than",
      "flyql": "count>10",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_less_than",
      "flyql": "count<100",
      "expected_ids": [1, 2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "int_greater_or_equals",
      "flyql": "count>=100",
      "expected_ids": [3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "float_less_than",
      "flyql": "price<50.0",
      "expected_ids": [1, 3, 4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "float_greater_or_equals",
      "flyql": "price>=50.0",
      "expected_ids": [2, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "bool_truthy",
      "flyql": "active",
      "expected_ids": [1, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "bool_not_truthy",
      "flyql": "not active",
      "expected_ids": [2, 4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "date_less_or_equals",
      "flyql": "created_at<='2023-06-15'",
      "expected_ids": [1, 2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "and_condition",
      "flyql": "active and status=200",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "or_condition",
      "flyql": "env='prod' or env='dev'",
      "expected_ids": [1, 3, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "in_integers",
      "flyql": "status in [200, 201]",
      "expected_ids": [1, 2, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "not_in_integers",
      "flyql": "status not in [200, 404]",
      "expected_ids": [4, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "in_strings",
      "flyql": "env in ['prod', 'staging']",
      "expected_ids": [1, 2, 4, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "truthy_string",
      "flyql": "message",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "truthy_int",
      "flyql": "count",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "not_truthy_string",
      "flyql": "not message",
      "expected_ids": [4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "grouped_logic",
      "flyql": "(status=200 or status=201) and active",
      "expected_ids": [1, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_level1_region",
      "flyql": "meta.region='us-east'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_level1_tier",
      "flyql": "meta.tier='premium'",
      "expected_ids": [1, 4, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_level2_city",
      "flyql": "meta.location.city='NYC'",
      "expected_ids": [1, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_level3_provider_aws",
      "flyql": "meta.location.cloud.provider='aws'",
      "expected_ids": [1, 3],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_level3_provider_azure",
      "flyql": "meta.location.cloud.provider='azure'",
      "expected_ids": [5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_native_level1_region",
      "flyql": "meta_json.region='us-east'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "json_native_level2_city",
      "flyql": "meta_json.location.city='NYC'",
      "expected_ids": [1, 5],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "json_native_level3_provider",
      "flyql": "meta_json.location.cloud.provider='aws'",
      "expected_ids": [1, 3],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "spaced_string_equals",
      "flyql": "message = 'hello'",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "spaced_int_less_than",
      "flyql": "count < 100",
      "expected_ids": [1, 2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "spaced_int_greater_or_equals",
      "flyql": "count >= 100",
      "expected_ids": [3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "spaced_and_condition",
      "flyql": "active and status = 200",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "json_dotted_key_equals",
      "flyql": "meta.'dc.region'='us-1'",
      "expected_ids": [1, 3, 5],
      "databases": ["postgresql"]
    },
    {
      "name": "json_dotted_key_not_equals",
      "flyql": "meta.'dc.region'!='us-1'",
      "expected_ids": [2, 4, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "json_dotted_key_in_list",
      "flyql": "meta.'dc.region' in ['us-1', 'eu-1']",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "json_dotted_key_truthy",
      "flyql": "meta.'dc.region'",
      "expected_ids": [1, 2, 3, 4, 5, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonb_array_index_equals",
      "flyql": "meta.tags.0='web'",
      "expected_ids": [1, 3, 5],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonb_array_index_in_list",
      "flyql": "meta.tags.0 in ['web', 'iot']",
      "expected_ids": [1, 3, 4, 5],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonb_quoted_integer_key_equals",
      "flyql": "meta.'0'='zero-a'",
      "expected_ids": [1, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonb_quoted_integer_key_in_list",
      "flyql": "meta.'0' in ['zero-a', 'zero-c']",
      "expected_ids": [1, 3, 4, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "map_equals",
      "flyql": "metadata.dc='us-1'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "starrocks", "postgresql"]
    },
    {
      "name": "map_not_equals",
      "flyql": "metadata.dc!='us-1'",
      "expected_ids": [2, 4, 6],
      "databases": ["clickhouse", "starrocks", "postgresql"]
    },
    {
      "name": "map_tier_premium",
      "flyql": "metadata.tier='premium'",
      "expected_ids": [1, 4, 6],
      "databases": ["clickhouse", "starrocks", "postgresql"]
    },
    {
      "name": "map_in_list",
      "flyql": "metadata.dc in ['us-1', 'eu-1']",
      "expected_ids": [1, 2, 3, 5, 6],
      "databases": ["clickhouse", "starrocks", "postgresql"]
    },
    {
      "name": "array_index_equals",
      "flyql": "tags.1='web'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "array_index_not_equals",
      "flyql": "tags.1!='web'",
      "expected_ids": [2, 4, 6],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "array_index_second_element",
      "flyql": "tags.2='api'",
      "expected_ids": [1, 2],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "map_and_array_combined",
      "flyql": "metadata.tier='premium' and tags.1='web'",
      "expected_ids": [1],
      "databases": ["clickhouse", "starrocks"]
    },
    {
      "name": "pg_array_index_equals",
      "flyql": "tags.0='web'",
      "expected_ids": [1, 3, 5],
      "databases": ["postgresql"]
    },
    {
      "name": "pg_array_index_not_equals",
      "flyql": "tags.0!='web'",
      "expected_ids": [2, 4, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "pg_array_index_second_element",
      "flyql": "tags.1='api'",
      "expected_ids": [1, 2],
      "databases": ["postgresql"]
    },
    {
      "name": "pg_map_and_array_combined",
      "flyql": "metadata.tier='premium' and tags.0='web'",
      "expected_ids": [1],
      "databases": ["postgresql"]
    },
    {
      "name": "at_column_string_equals",
      "flyql": "user@host='alice@web1'",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "at_column_string_not_equals",
      "flyql": "user@host!='alice@web1'",
      "expected_ids": [2, 3, 4, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "at_column_string_like",
      "flyql": "user@host='*@web1'",
      "expected_ids": [1, 3, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "at_column_in_list",
      "flyql": "user@host in ['alice@web1', 'bob@web2']",
      "expected_ids": [1, 2],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "has_string_substring",
      "flyql": "message has 'hello'",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "not_has_string_substring",
      "flyql": "message not has 'hello'",
      "expected_ids": [2, 4, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "has_string_world",
      "flyql": "message has 'world'",
      "expected_ids": [2, 3],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "has_string_combined_and",
      "flyql": "message has 'hello' and active",
      "expected_ids": [1, 3, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "has_string_combined_or",
      "flyql": "message has 'error' or message has 'world'",
      "expected_ids": [2, 3, 5],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "jsonstring_segmented_string_equals",
      "flyql": "json_meta.region='us-east'",
      "expected_ids": [1, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_segmented_number_equals",
      "flyql": "json_meta.count=42",
      "expected_ids": [1],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_segmented_number_greater",
      "flyql": "json_meta.count>50",
      "expected_ids": [3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_segmented_regex",
      "flyql": "json_meta.level~'err.*'",
      "expected_ids": [3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_segmented_in_list",
      "flyql": "json_meta.level in ['info', 'error']",
      "expected_ids": [1, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_truthy_object",
      "flyql": "json_meta",
      "expected_ids": [1, 2, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_falsy_null_and_empty",
      "flyql": "not json_meta",
      "expected_ids": [4, 5, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_truthy_segmented",
      "flyql": "json_meta.region",
      "expected_ids": [1, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_falsy_segmented",
      "flyql": "not json_meta.region",
      "expected_ids": [2, 4, 5, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_has_key",
      "flyql": "json_meta has 'region'",
      "expected_ids": [1, 3],
      "databases": ["postgresql"]
    },
    {
      "name": "jsonstring_not_has_key",
      "flyql": "json_meta not has 'region'",
      "expected_ids": [2, 5, 6],
      "databases": ["postgresql"]
    },
    {
      "name": "transformer_upper_equals",
      "flyql": "message|upper = 'HELLO'",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_lower_equals",
      "flyql": "message|lower = 'world'",
      "expected_ids": [2],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_len_greater_than",
      "flyql": "message|len > 10",
      "expected_ids": [3],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_len_equals_zero",
      "flyql": "message|len = 0",
      "expected_ids": [4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_chained_lower_len_gt",
      "flyql": "message|lower|len > 5",
      "expected_ids": [3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_chained_upper_len_eq",
      "flyql": "message|upper|len = 5",
      "expected_ids": [1, 2],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_len_gte",
      "flyql": "message|len >= 10",
      "expected_ids": [3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_len_lt",
      "flyql": "message|len < 5",
      "expected_ids": [4],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_upper_and_active",
      "flyql": "message|upper = 'HELLO' and active",
      "expected_ids": [1],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    },
    {
      "name": "transformer_len_or_count",
      "flyql": "message|len > 5 or count > 100",
      "expected_ids": [3, 5, 6],
      "databases": ["clickhouse", "postgresql", "starrocks"]
    }
  ]
}
