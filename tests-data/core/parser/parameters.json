{
  "version": "1.0",
  "description": "Parameter placeholder test cases",
  "test_suite": "parameters",
  "tests": [
    {
      "name": "named_basic",
      "input": "status=$code",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "status",
          "operator": "=",
          "value": {"name": "code", "positional": false},
          "value_type": "parameter"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "positional_basic",
      "input": "status=$1",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "status",
          "operator": "=",
          "value": {"name": "1", "positional": true},
          "value_type": "parameter"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "named_with_underscore",
