{
  "version": "1.0",
  "description": "Query parser transformer test cases",
  "test_suite": "core_parser_transformers",
  "tests": [
    {
      "name": "simple_transformer_equals",
      "input": "message|upper = 'ERROR'",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "message|upper",
          "operator": "=",
          "value": "ERROR",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "chained_transformer_greater_than",
      "input": "field|lower|len > 10",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "field|lower|len",
          "operator": ">",
          "value": 10.0,
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "transformer_with_boolean",
      "input": "message|upper = 'ERROR' and status > 400",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "and",
        "expression": null,
        "left": {
          "bool_operator": "",
          "expression": {
            "key": "message|upper",
            "operator": "=",
            "value": "ERROR",
            "value_type": "string"
          },
          "left": null,
          "right": null
        },
        "right": {
          "bool_operator": "",
          "expression": {
            "key": "status",
            "operator": ">",
            "value": 400.0,
            "value_type": "number"
          },
          "left": null,
          "right": null
        }
      }
    },
    {
      "name": "unknown_transformer_error",
      "input": "field|bogus = 'x'",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "field|bogus",
          "operator": "=",
          "value": "x",
          "value_type": "string"
        },
        "left": null,
        "right": null
      }
    },
    {
      "name": "type_incompatible_chain",
      "input": "field|len|upper > 5",
      "expected_result": "success",
      "expected_ast": {
        "bool_operator": "",
        "expression": {
          "key": "field|len|upper",
          "operator": ">",
          "value": 5.0,
          "value_type": "number"
        },
        "left": null,
        "right": null
      }
    }
  ]
}
