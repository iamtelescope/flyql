    {
      "name": "error_regex_operator",
      "input": "timestamp~ago(1h)",
      "expected_result": "error",
      "expected_error": {
        "errno": 72,
        "message_contains": "operator '~' is not valid with a temporal function"
      }
    },
    {
      "name": "error_not_regex_operator",
      "input": "timestamp!~ago(1h)",
      "expected_result": "error",
      "expected_error": {
        "errno": 72,
        "message_contains": "operator '!~' is not valid with a temporal function"
      }
    },
    {
      "name": "error_unknown_function",
      "input": "timestamp>unknown(1h)",
      "expected_result": "error",
      "expected_error": {
        "errno": 70,
        "message_contains": "unknown function"
      }
    },
    {
      "name": "error_ago_empty",
      "input": "timestamp>ago()",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "requires a duration"
      }
    },
    {
      "name": "error_ago_string_arg",
      "input": "timestamp>ago('Europe/Berlin')",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
        "message_contains": "requires a duration"
      }
    },
    {
      "name": "error_now_with_args",
      "input": "timestamp>now(1h)",
      "expected_result": "error",
      "expected_error": {
        "errno": 73,
