<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>FlyQL E2E Report</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f4f6f9;
        color: #222;
      }

      header {
        background: #16213e;
        color: #fff;
        padding: 20px 32px;
      }

      header h1 {
        font-size: 1.4rem;
        font-weight: 600;
      }

      header .ts {
        font-size: 0.8rem;
        opacity: 0.6;
        margin-top: 3px;
      }

      .summary {
        display: flex;
        gap: 12px;
        padding: 16px 32px;
        background: #fff;
        border-bottom: 1px solid #e4e7ec;
      }

      .stat {
        padding: 8px 20px;
        border-radius: 6px;
        text-align: center;
        min-width: 90px;
      }

      .stat .n {
        font-size: 1.8rem;
        font-weight: 700;
      }

      .stat .l {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.8;
      }

      .total   { background: #eef2ff; color: #3730a3; }
      .spassed { background: #f0fdf4; color: #166534; }
      .sfailed { background: #fef2f2; color: #991b1b; }

      .wrap {
        padding: 24px 32px;
      }

      .section-title {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: #6b7280;
        margin: 0 0 10px;
      }

      .section-title + table {
        margin-bottom: 28px;
      }

      .lang-stats {
        font-size: 0.75rem;
        font-weight: 400;
        color: #6b7280;
        margin-left: 8px;
        text-transform: none;
        letter-spacing: 0;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
        margin-bottom: 28px;
      }

      thead {
        background: #16213e;
        color: #fff;
      }

      th {
        padding: 11px 14px;
        text-align: left;
        font-size: 0.73rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-weight: 600;
      }

      td {
        padding: 9px 14px;
        border-bottom: 1px solid #f0f2f5;
        font-size: 0.85rem;
        vertical-align: top;
      }

      tr:last-child td {
        border-bottom: none;
      }

      tr.pass:hover td { background: #f0fdf4; }
      tr.fail:hover td { background: #fff5f5; }
      tr.fail td       { background: #fffbfb; }

      .st {
        text-align: center;
        white-space: nowrap;
      }

      .icon { font-size: 1rem; }
      tr.pass .icon { color: #16a34a; }
      tr.fail .icon { color: #dc2626; }

      .db {
        display: inline-block;
        padding: 2px 9px;
        border-radius: 10px;
        font-size: 0.72rem;
        font-weight: 600;
      }

      .ch { background: #fff3e0; color: #c2410c; }
      .pg { background: #eff6ff; color: #1d4ed8; }

      .name {
        font-weight: 500;
      }

      code {
        font-family: 'SFMono-Regular', Consolas, monospace;
        background: #f8f9fa;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.78rem;
        word-break: break-all;
      }

      .ids {
        font-family: monospace;
        font-size: 0.82rem;
      }

      .ids.mismatch {
        color: #dc2626;
        font-weight: 600;
      }

      .err {
        color: #dc2626;
        font-size: 0.78rem;
        margin-top: 4px;
        font-style: italic;
      }

      .dur {
        font-family: monospace;
        font-size: 0.82rem;
        color: #6b7280;
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>FlyQL E2E Test Report</h1>
      <div class="ts">{{ generated_at }}</div>
    </header>

    <div class="summary">
      <div class="stat total">
        <div class="n">{{ total }}</div>
        <div class="l">Total</div>
      </div>
      <div class="stat spassed">
        <div class="n">{{ passed }}</div>
        <div class="l">Passed</div>
      </div>
      <div class="stat sfailed">
        <div class="n">{{ failed }}</div>
        <div class="l">Failed</div>
      </div>
    </div>

    <div class="wrap">

      <p class="section-title">Infrastructure</p>
      <table>
        <thead>
          <tr>
            <th>Stage status</th>
            <th>Step</th>
            <th>Duration</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {% for step in infra_steps %}
          <tr class="{{ 'pass' if step.success else 'fail' }}">
            <td class="st"><span class="icon">{{ '✓' if step.success else '✗' }}</span></td>
            <td class="name">{{ step.name }}</td>
            <td class="dur">{{ step.duration }}</td>
            <td>{{ step.detail }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

      {% for group in language_groups %}
      {% set where_results = group.results | rejectattr('kind', 'equalto', 'select') | list %}
      {% set select_results = group.results | selectattr('kind', 'equalto', 'select') | list %}

      <p class="section-title">
        {{ group.label }}
        <span class="lang-stats">
          {{ group.passed }}/{{ group.total }} passed
          {%- if group.failed %} · {{ group.failed }} failed{% endif %}
        </span>
      </p>

      {% if where_results %}
      <p class="subsection-title">Filter (WHERE) Tests</p>
      <table>
        <thead>
          <tr>
            <th class="st"></th>
            <th>DB</th>
            <th>Test</th>
            <th>FlyQL</th>
            <th>Generated SQL</th>
            <th>Expected IDs</th>
            <th>Returned IDs</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          {% for r in where_results %}
          <tr class="{{ 'pass' if r.passed else 'fail' }}">
            <td class="st"><span class="icon">{{ '✓' if r.passed else '✗' }}</span></td>
            <td><span class="db {{ 'ch' if r.database == 'clickhouse' else 'pg' }}">{{ r.database }}</span></td>
            <td class="name">{{ r.name }}</td>
            <td><code>{{ r.flyql }}</code></td>
            <td><code>{{ r.sql }}</code></td>
            <td class="ids">{{ (r.expected_ids or []) | join(', ') }}</td>
            <td class="ids{{ ' mismatch' if not r.passed and not r.error }}">
              {%- if r.returned_ids -%}
                {{ r.returned_ids | join(', ') }}
              {%- elif not r.passed and not r.error -%}
                <span class="err">(no rows)</span>
              {%- endif -%}
            </td>
            <td class="err">{{ r.error or '' }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if select_results %}
      <p class="subsection-title">Select Tests</p>
      <table>
        <thead>
          <tr>
            <th class="st"></th>
            <th>DB</th>
            <th>Test</th>
            <th>Select Columns</th>
            <th>Generated SQL</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          {% for r in select_results %}
          <tr class="{{ 'pass' if r.passed else 'fail' }}">
            <td class="st"><span class="icon">{{ '✓' if r.passed else '✗' }}</span></td>
            <td><span class="db {{ 'ch' if r.database == 'clickhouse' else 'pg' }}">{{ r.database }}</span></td>
            <td class="name">{{ r.name }}</td>
            <td><code>{{ r.flyql }}</code></td>
            <td><code>{{ r.sql }}</code></td>
            <td class="err">{{ r.error or '' }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% endfor %}

    </div>
  </body>
</html>
