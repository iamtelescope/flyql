{
  "version": "1.0",
  "description": "Temporal function SQL generation tests for ClickHouse",
  "test_suite": "functions",
  "tests": [
    {
      "name": "ago_single_duration",
      "input": "ts>ago(1h)",
      "expected_result": "success",
      "expected_sql": "ts > (now() - INTERVAL 1 HOUR)"
    },
    {
      "name": "ago_compound_duration",
      "input": "ts>ago(1h30m)",
      "expected_result": "success",
      "expected_sql": "ts > (now() - INTERVAL 1 HOUR - INTERVAL 30 MINUTE)"
    },
    {
      "name": "ago_weeks",
      "input": "ts>ago(2w)",
      "expected_result": "success",
      "expected_sql": "ts > (now() - INTERVAL 14 DAY)"
    },
    {
      "name": "now",
      "input": "ts>now()",
      "expected_result": "success",
      "expected_sql": "ts > now()"
    },
    {
      "name": "today_default_timezone",
      "input": "ts>today()",
      "expected_result": "success",
      "expected_sql": "ts > toDate(toTimezone(now(), 'UTC'))"
    },
    {
      "name": "today_explicit_timezone",
      "input": "ts>today('Europe/Berlin')",
      "expected_result": "success",
      "expected_sql": "ts > toDate(toTimezone(now(), 'Europe/Berlin'))"
    },
    {
      "name": "startof_day",
      "input": "ts>startOf('day')",
      "expected_result": "success",
      "expected_sql": "ts > toStartOfDay(toTimezone(now(), 'UTC'))"
    },
    {
      "name": "startof_week",
      "input": "ts>startOf('week')",
      "expected_result": "success",
      "expected_sql": "ts > toStartOfWeek(toTimezone(now(), 'UTC'), 1)"
    },
    {
      "name": "startof_month_with_timezone",
      "input": "ts>startOf('month', 'Asia/Tokyo')",
      "expected_result": "success",
      "expected_sql": "ts > toStartOfMonth(toTimezone(now(), 'Asia/Tokyo'))"
    }
  ]
}
